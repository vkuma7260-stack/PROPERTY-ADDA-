<script>
// ── DATA ──
let properties = [
  { id:1, title:"3 BHK Luxury Flat", type:"flat", price:"₹55 Lakh", location:"Trikuta Nagar", beds:3, baths:2, area:"1450", status:"Ready to Move", img:"" },
  { id:2, title:"2 BHK Flat Near Market", type:"flat", price:"₹32 Lakh", location:"Gandhi Nagar", beds:2, baths:1, area:"980", status:"New Launch", img:"" },
  { id:3, title:"Residential Plot 200 Sq Yd", type:"plot", price:"₹18 Lakh", location:"Barnai", beds:0, baths:0, area:"1800", status:"Ready to Move", img:"" },
  { id:4, title:"2 BHK Furnished Rental", type:"rental", price:"₹12K/month", location:"Channi Himmat", beds:2, baths:1, area:"850", status:"Ready to Move", img:"" },
  { id:5, title:"4 BHK Independent Floor", type:"flat", price:"₹78 Lakh", location:"Bakshi Nagar", beds:4, baths:3, area:"2100", status:"Under Construction", img:"" },
  { id:6, title:"Commercial Plot 500 Sq Yd", type:"plot", price:"₹65 Lakh", location:"Sidhra", beds:0, baths:0, area:"4500", status:"New Launch", img:"" },
  { id:7, title:"1 BHK Studio Apartment", type:"rental", price:"₹7K/month", location:"Nanak Nagar", beds:1, baths:1, area:"480", status:"Ready to Move", img:"" },
  { id:8, title:"3 BHK Premium Flat", type:"flat", price:"₹62 Lakh", location:"Roop Nagar", beds:3, baths:2, area:"1600", status:"New Launch", img:"" },
];
let nextId = 9;
let currentFilter = 'all';
let locationFilter = '';

// ── RENDER ──
function getBadgeClass(type) {
  return type==='flat'?'badge-flat':type==='plot'?'badge-plot':'badge-rental';
}
function getStatusClass(s) {
  if(s==='Ready to Move') return 'badge-ready';
  if(s==='Under Construction') return 'badge-under';
  return 'badge-new';
}
function renderPlaceholder(type) {
  const icons = {flat:'🏢',plot:'🌱',rental:'🔑'};
  const labels = {flat:'Flat',plot:'Plot',rental:'Rental'};
  return `<div class="prop-img-placeholder"><div class="house-icon">${icons[type]}</div><span style="font-size:13px;color:#999">${labels[type]}</span></div>`;
}
function renderCards() {
  const grid = document.getElementById('listingsGrid');
  let filtered = properties.filter(p => {
    const matchType = currentFilter==='all' || p.type===currentFilter;
    const matchLoc = !locationFilter || p.location===locationFilter;
    return matchType && matchLoc;
  });
  document.getElementById('listingCount').textContent = `Showing ${filtered.length} listing${filtered.length!==1?'s':''}`;
  document.getElementById('totalProps').textContent = properties.length;
  document.getElementById('resultCount').textContent = `${filtered.length} results`;
  if(filtered.length===0){
    grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:60px;color:#888;"><div style="font-size:48px;margin-bottom:12px;">🏚️</div><p>No properties found. Try a different filter.</p></div>`;
    return;
  }
  grid.innerHTML = filtered.map(p=>`
    <div class="prop-card" data-type="${p.type}" data-id="${p.id}">
      <div class="prop-img">
        ${p.img ? `<img src="${p.img}" alt="${p.title}" onerror="this.parentElement.innerHTML='${renderPlaceholder(p.type).replace(/'/g,"\\'")}'">`  : renderPlaceholder(p.type)}
        <span class="type-badge ${getBadgeClass(p.type)}">${p.type.charAt(0).toUpperCase()+p.type.slice(1)}</span>
        <span class="status-badge ${getStatusClass(p.status)}">${p.status}</span>
      </div>
      <div class="prop-body">
        <div class="prop-price">${p.price}</div>
        <div class="prop-title">${p.title}</div>
        <div class="prop-location">${p.location}, Jammu</div>
        <div class="prop-specs">
          ${p.beds>0?`<div class="spec-item">🛏️ ${p.beds} Bed${p.beds>1?'s':''}</div>`:''}
          ${p.baths>0?`<div class="spec-item">🚿 ${p.baths} Bath${p.baths>1?'s':''}</div>`:''}
          ${p.area?`<div class="spec-item">📐 ${p.area} sq ft</div>`:''}
        </div>
        <div class="prop-actions">
          <button class="btn-call" onclick="openCallModal(${p.id})">📞 Call Agent</button>
          <button class="btn-details">View Details</button>
        </div>
      </div>
    </div>
  `).join('');
}

function filterProps(type, btn) {
  currentFilter = type;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  if(btn) btn.classList.add('active');
  renderCards();
}
function filterByLocation(loc) { locationFilter=loc; renderCards(); }
function applyFilters() { renderCards(); }
function doSearch() {
  const type = document.getElementById('searchType').value.toLowerCase();
  const loc = document.getElementById('searchLocation').value;
  if(type) currentFilter = type;
  if(loc) locationFilter = loc;
  renderCards();
  document.querySelector('.main-layout').scrollIntoView({behavior:'smooth'});
}

// ── MODALS ──
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function openInquiryModal() { openModal('inquiryModal'); }
window.addEventListener('click', e => {
  if(e.target.classList.contains('modal-overlay')) e.target.classList.remove('open');
});
function openCallModal(propId) {
  // Reset
  document.getElementById('callName').value = '';
  document.getElementById('callPhone').value = '';
  document.getElementById('callDate').value = '';
  document.getElementById('callSuccess').style.display = 'none';
  // Set min date to today
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('callDate').min = today;

  // Auto-fill property info
  const prop = properties.find(p => p.id === propId);
  if(prop) {
    document.getElementById('callPropTitle').textContent = prop.title;
    document.getElementById('callPropLocation').textContent = '📍 ' + prop.location + ', Jammu';
    document.getElementById('callPropPrice').textContent = prop.price;
    const imgEl = document.getElementById('callPropImg');
    if(prop.img) {
      imgEl.src = prop.img;
      imgEl.style.display = 'block';
    } else {
      imgEl.style.display = 'none';
    }
    document.getElementById('callPropPreview').style.display = 'flex';
  } else {
    document.getElementById('callPropPreview').style.display = 'none';
  }
  window._callPropId = propId;
  openModal('inquiryModal');
}

function submitCallBooking() {
  const name = document.getElementById('callName').value.trim();
  const phone = document.getElementById('callPhone').value.trim();
  const date = document.getElementById('callDate').value;
  if(!name) { alert('Please enter your name'); return; }
  if(!phone || phone.length < 10) { alert('Please enter a valid 10-digit mobile number'); return; }
  if(!date) { alert('Please select a preferred date'); return; }

  const prop = properties.find(p => p.id === window._callPropId);
  const propInfo = prop ? `🏠 Property: ${prop.title} (${prop.location})\n💰 Price: ${prop.price}` : '';

  const msg = encodeURIComponent(`Hello Sunny,\n\nNew Call Booking Request:\n👤 Name: ${name}\n📞 Mobile: ${phone}\n📅 Date: ${date}\n${propInfo}\n\nPlease call to confirm.`);

  document.getElementById('callSuccess').style.display = 'block';
  setTimeout(() => {
    closeModal('inquiryModal');
    document.getElementById('callSuccess').style.display = 'none';
    window.open(`https://wa.me/917006628484?text=${msg}`, '_blank');
  }, 1200);
}

// ── ADMIN ──
function showAdmin() { openModal('adminLoginModal'); document.getElementById('adminPwd').value=''; document.getElementById('pwdError').style.display='none'; }
function checkAdmin() {
  const pwd = document.getElementById('adminPwd').value;
  if(pwd==='thirdeyetechnologies'){
    closeModal('adminLoginModal');
    document.getElementById('adminPanel').classList.add('show');
    document.querySelector('nav').style.display='none';
    document.querySelector('.topbar').style.display='none';
    renderAdminTable();
    window.scrollTo(0,0);
  } else {
    document.getElementById('pwdError').style.display='block';
  }
}
function logoutAdmin() {
  document.getElementById('adminPanel').classList.remove('show');
  document.querySelector('nav').style.display='flex';
  document.querySelector('.topbar').style.display='flex';
}
function switchTab(tab, el) {
  document.querySelectorAll('.admin-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.admin-content').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-'+tab).classList.add('active');
}
function renderAdminTable() {
  const tbody = document.getElementById('adminTableBody');
  tbody.innerHTML = properties.map((p,i)=>`
    <tr>
      <td>${i+1}</td>
      <td>${p.title}</td>
      <td><span class="type-badge ${getBadgeClass(p.type)}" style="position:static;font-size:11px;">${p.type}</span></td>
      <td>${p.price}</td>
      <td>${p.location}</td>
      <td>${p.beds||'—'}</td>
      <td>${p.area} sqft</td>
      <td>${p.status}</td>
      <td><button class="del-btn" onclick="deleteProp(${p.id})">Delete</button></td>
    </tr>
  `).join('');
}
function deleteProp(id) {
  if(confirm('Delete this property?')){ properties=properties.filter(p=>p.id!==id); renderAdminTable(); renderCards(); }
}
function addProperty() {
  const title = document.getElementById('newTitle').value.trim();
  const price = document.getElementById('newPrice').value.trim();
  const locSelect = document.getElementById('newLocation').value;
  const locCustom = document.getElementById('newLocationCustom').value.trim();
  const location = locSelect === '__custom__' ? locCustom : locSelect;

  if(!title) { alert('Please enter a property title'); return; }
  if(!price) { alert('Please enter a price'); return; }
  if(!location) { alert('Please select or type a location'); return; }

  const p = {
    id: nextId++,
    title, price, location,
    type: document.getElementById('newType').value,
    beds: parseInt(document.getElementById('newBeds').value) || 0,
    baths: parseInt(document.getElementById('newBaths').value) || 1,
    area: document.getElementById('newArea').value || 'N/A',
    status: document.getElementById('newStatus').value,
    desc: document.getElementById('newDesc').value.trim(),
    img: window._propImgData || ''
  };
  properties.unshift(p);
  renderAdminTable();
  renderCards();
  document.getElementById('addPropSuccess').style.display = 'block';
  setTimeout(() => { document.getElementById('addPropSuccess').style.display = 'none'; closeModal('addPropModal'); }, 1500);
  // Reset all fields
  ['newTitle','newPrice','newBeds','newBaths','newArea','newDesc'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('newLocation').value = '';
  document.getElementById('newLocationCustom').style.display = 'none';
  document.getElementById('newLocationCustom').value = '';
  window._propImgData = '';
  document.getElementById('propImgPreview').style.display = 'none';
  document.getElementById('propImgLabel').textContent = '📷 Click or drag to upload property photo';
  document.getElementById('propImgDrop').style.borderColor = '#ddd';
  document.getElementById('propImgFile').value = '';
}

function askUploadPwd() {
  document.getElementById('uploadPwdInput').value = '';
  document.getElementById('uploadPwdError').style.display = 'none';
  openModal('uploadPwdModal');
}
function checkUploadPwd() {
  const pwd = document.getElementById('uploadPwdInput').value;
  if(pwd === 'thirdeyetechnologies') {
    closeModal('uploadPwdModal');
    document.getElementById('propImgFile').click();
  } else {
    document.getElementById('uploadPwdError').style.display = 'block';
    document.getElementById('uploadPwdInput').value = '';
  }
}

function previewPropImg(input) {
  if(input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      window._propImgData = e.target.result;
      document.getElementById('propImgThumb').src = e.target.result;
      document.getElementById('propImgPreview').style.display = 'block';
      document.getElementById('propImgLabel').textContent = '✅ ' + input.files[0].name;
      document.getElementById('propImgDrop').style.borderColor = 'var(--gold)';
    };
    reader.readAsDataURL(input.files[0]);
  }
}
function handlePropImgDrop(e) {
  e.preventDefault();
  document.getElementById('propImgDrop').style.borderColor = '#ddd';
  const file = e.dataTransfer.files[0];
  if(file && file.type.startsWith('image/')) {
    const dt = new DataTransfer();
    dt.items.add(file);
    const inp = document.getElementById('propImgFile');
    inp.files = dt.files;
    previewPropImg(inp);
  }
}
window._propImgData = '';

// Custom location toggle
document.getElementById('newLocation').addEventListener('change', function() {
  const custom = document.getElementById('newLocationCustom');
  if(this.value === '__custom__') {
    custom.style.display = 'block';
    custom.focus();
  } else {
    custom.style.display = 'none';
  }
});

// ── INIT ──
renderCards();
